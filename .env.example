# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aashley_db

# SMTP (Hostinger) – contact & admission forms
# Use smtp.hostinger.com (not localhost) so Docker/containers can reach Hostinger.
# After editing .env: restart Node or rebuild/restart your Docker container.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-mailbox@yourdomain.com
# Use double quotes if password contains # @ or spaces
SMTP_PASS="your-mailbox-password"
# Display name + address (recommended for production)
SMTP_FROM="Aashley International School <noreply@yourdomain.com>"

# Optional: STARTTLS instead of SSL – use 587 + false
# SMTP_PORT=587
# SMTP_SECURE=false

# Optional: where form submissions are delivered
# ENQUIRY_EMAIL_TO=enquiry.aashley@gmail.com
