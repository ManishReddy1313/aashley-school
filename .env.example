# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aashley_db

# SMTP (Hostinger mail) – for sending contact & admission form submissions by email
# Get these from Hostinger: Email → your mailbox → Connect Apps & Devices / SMTP
# After editing .env you must restart the server (npm run dev or your process).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=2525
SMTP_SECURE=false
# For 2525 secure must stay false. (If you switch to 587 or 465, update mail.ts as needed.)
SMTP_USER=your-mailbox@yourdomain.com
# Use double quotes if password contains # @ or spaces (otherwise # starts a comment)
SMTP_PASS="your-mailbox-password"

# Optional: "From" address (defaults to SMTP_USER)
# SMTP_FROM=Aashley International School <noreply@yourdomain.com>

# Optional: where form submissions are sent (default: enquiry.aashley@gmail.com)
# ENQUIRY_EMAIL_TO=enquiry.aashley@gmail.com
