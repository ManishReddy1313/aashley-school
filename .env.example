# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aashley_db

# Resend (HTTPS API — no SMTP; works in Docker)
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Verified domain sender, e.g. "Aashley School <noreply@yourdomain.com>"
# For testing only, Resend allows: onboarding@resend.dev
EMAIL_FROM="Aashley International School <onboarding@resend.dev>"
# Where contact & admission form notifications are delivered
ENQUIRY_EMAIL_TO=enquiry.aashley@gmail.com

# After editing .env: restart Node or rebuild/restart Docker.
